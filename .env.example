# ===== msc-academy-app (Next.js) — variáveis de ambiente =====

# Supabase (projeto msc-hub, online). CRM lê leads/purchases via service_role (server-only, NUNCA no cliente).
SUPABASE_URL=https://SEUPROJETO.supabase.co
# chave publicável (anon) — grava lead via RLS insert-only (gate do blog / funil)
SUPABASE_KEY=sb_publishable_xxx
# service_role (server-only) — leitura do CRM (NUNCA no cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Painel admin (gate de senha — padrão da casa admin/admin)
ADMIN_PASSWORD=admin
ADMIN_JWT_SECRET=troque-por-uma-string-aleatoria-forte
